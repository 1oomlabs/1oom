{
  "name": "@loomlabs/plugin-elizaos",
  "version": "0.0.0",
  "description": "ElizaOS plugin that exposes loomlabs workflow marketplace and workflow creation as agent actions.",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsx src/runtime-smoke.test.ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@loomlabs/keeperhub-client": "workspace:*",
    "@loomlabs/llm": "workspace:*",
    "@loomlabs/schema": "workspace:*",
    "@loomlabs/templates": "workspace:*",
    "viem": "^2.48.4",
    "zod": "^3.24.1"
  },
  "peerDependencies": {
    "@elizaos/core": "*"
  },
  "peerDependenciesMeta": {
    "@elizaos/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@elizaos/core": "2.0.0-alpha.77",
    "tsx": "^4.20.0",
    "typescript": "^5.7.2"
  }
}
