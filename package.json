{
  "name": "loomlabs",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "pnpm db:deploy && turbo run dev",
    "dev:fast": "turbo run dev",
    "setup": "pnpm install && pnpm db:deploy && pnpm db:seed",
    "db:deploy": "pnpm --filter @loomlabs/api db:deploy",
    "db:migrate": "pnpm --filter @loomlabs/api db:migrate",
    "db:seed": "pnpm --filter @loomlabs/api db:seed",
    "db:studio": "pnpm --filter @loomlabs/api db:studio",
    "db:reset": "pnpm --filter @loomlabs/api db:reset",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
